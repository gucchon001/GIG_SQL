    CASE 
        WHEN up.current_occupation = 1 THEN '高校生（卒業見込み）'
        WHEN up.current_occupation = 2 THEN '大学生'
        WHEN up.current_occupation = 3 THEN '短大・専門学生'
        WHEN up.current_occupation = 4 THEN '大学院生'
        WHEN up.current_occupation = 5 THEN 'フリーター'
        WHEN up.current_occupation = 6 THEN '派遣社員'
        WHEN up.current_occupation = 7 THEN '契約社員'
        WHEN up.current_occupation = 8 THEN '正社員'
        WHEN up.current_occupation = 9 THEN '主婦・主夫'
        WHEN up.current_occupation = 10 THEN '無職'
        WHEN up.current_occupation = 11 THEN 'その他'
        ELSE up.current_occupation
    END AS "現在の職業",
    uebv.school_name AS "学校名",
    uebv.faculty_name AS "学部",
    uebv.department_name AS "学科",
    uebv.school_year_name AS "学年",
    uebv.humanities_and_sciences_name AS "文理",
    ua.applied_urgent_flag AS "急募求人",
    uebv.entrance_exam_classification AS "大学入試",
    NULL AS "入会経路",
    CASE 
        WHEN up.current_occupation IN (1, 2, 3, 4) THEN '大学生'
        ELSE '既卒'
    END AS "現在の職業（セグメント）",
    NULL AS "応募回数（セグメント）",
    NULL AS "応募回数",
    jbv.job_group_name AS "企業群（セグメント）",
    CASE 
        WHEN ua.applied_group = 1 THEN 'S'
        WHEN ua.applied_group = 2 THEN 'A'
        WHEN ua.applied_group = 3 THEN 'B'
        WHEN ua.applied_group = 4 THEN 'C'
        WHEN ua.applied_group = 5 THEN 'D'
        WHEN ua.applied_group = 6 THEN 'E'
        WHEN ua.applied_group = 7 THEN 'F'
        WHEN ua.applied_group = 8 THEN 'G'
        WHEN ua.applied_group = 9 THEN 'H'
        WHEN ua.applied_group = 10 THEN 'O'
        ELSE 'D'
    END AS "セグメント名",
    uebv.enroll_year AS "入学年",
    CASE 
        WHEN ua.submission_status = 1 THEN '未提出'
        WHEN ua.submission_status = 2 THEN '提出中'
        WHEN ua.submission_status = 3 THEN '差し戻し'
        WHEN ua.submission_status = 4 THEN '完了'
        ELSE ua.submission_status
    END AS "提出ステータス",
    CASE 
        WHEN ua.adoption_status_company = 1 THEN '未登録'
        WHEN ua.adoption_status_company = 2 THEN '採用'
        WHEN ua.adoption_status_company = 3 THEN '不合格'
        WHEN ua.adoption_status_company = 4 THEN '連絡取れず'
        WHEN ua.adoption_status_company = 5 THEN '辞退'
        WHEN ua.adoption_status_company = 6 THEN '欠席'
        WHEN ua.adoption_status_company = 7 THEN '応募重複'
        WHEN ua.adoption_status_company = 8 THEN '対象外'
        WHEN ua.adoption_status_company = 9 THEN '保留'
        ELSE NULL
    END AS "採用ステータス",
    DATE_FORMAT(ua.training_first_day, '%Y/%m/%d %H:%i:%s') AS "研修初日",
    CASE 
        WHEN ua.confirm_enrollment = 1 THEN '◯'
        WHEN ua.confirm_enrollment = 2 THEN '×'
        ELSE NULL
    END AS "在籍確認",
    NULL AS "データタイプ",
    DATE_FORMAT(ua.last_submission_datetime, '%Y/%m/%d %H:%i:%s') AS "最終提出日",
    DATE_FORMAT(ua.billing_confirmed_at, '%Y/%m/%d %H:%i:%s') AS "請求確定日",
    DATE_FORMAT(ua.submission_deadline, '%Y/%m/%d %H:%i:%s') AS "提出期限",
    ua.overdateline_count AS "提出期限超過月数",
    ua.pending_count AS "保留月数",
    am.name AS "最終変更者",
    DATE_FORMAT(ua.updated_at, '%Y/%m/%d %H:%i:%s') AS "更新日",
    'DUMMY' AS "終了列"
-- FROM clause
FROM user_applications ua
LEFT JOIN um_user_emails ue ON ua.user_id = ue.user_id AND ue.existence = 1 AND ue.member_id IS NOT NULL
LEFT JOIN um_users uu ON ue.user_id = uu.id
LEFT JOIN job_basic_view jbv ON ua.job_id = jbv.job_id
LEFT JOIN um_user_profiles up ON ua.user_id = up.user_id
LEFT JOIN prefectures p ON up.prefecture = p.id
LEFT JOIN cities ci ON up.city = ci.city_id
LEFT JOIN user_educatinal_backgrounds_view uebv ON ua.user_id = uebv.user_id
LEFT JOIN am_admins am ON ua.updated_by = am.id
WHERE DATE(ua.created_at) >= '2022-04-01' 
    AND ue.email NOT LIKE '%tomonokai-corp%' 
    AND ue.email NOT LIKE '%jukust.jp%' 
    AND up.full_name NOT LIKE '%TEST%' 
    AND up.full_name NOT LIKE '%テスト%' AND  DATE(ua.updated_at) BETWEEN '2024-10-17' AND '2025-07-31' AND ua.deleted_at IS NULL;
