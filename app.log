2025-08-01 20:21:44,327 - main - INFO - SELECT 
    cbi.brand_id AS "教室グループID",
    cbi.company_id AS "企業ID",
    cbi.prefecture_id AS "都道府県",
    cbi.plan AS "プラン",
    CASE 
        WHEN jbi.group = 1 THEN 'S'
        WHEN jbi.group = 2 THEN 'A'
        WHEN jbi.group = 3 THEN 'B'
        WHEN jbi.group = 4 THEN 'C'
        WHEN jbi.group = 5 THEN 'D'
        WHEN jbi.group = 6 THEN 'E'
        WHEN jbi.group = 7 THEN 'F'
        WHEN jbi.group = 8 THEN 'G'
        WHEN jbi.group = 9 THEN 'H'
        WHEN jbi.group = 10 THEN 'O'
        ELSE 'D'
    END AS "企業群",
    com.admin_note_1 AS "請求集計ID",
    COUNT(DISTINCT cbi.id) AS "掲載設定数",
    SUM(
        CASE 
            WHEN EXISTS(
                SELECT 1 
                FROM job_basic_informations jbi2
                JOIN urgent_jobs uj ON uj.job_id = jbi2.id
                JOIN contracts c ON c.id = uj.contract_id
                WHERE jbi2.classroom_id = cbi.id
                AND c.inactive_admin IS NULL
                AND NOW() BETWEEN c.start_datetime AND c.end_datetime
            ) 
            THEN 1 
            ELSE 0 
        END
    ) AS "急募求人数",
    CASE
        WHEN cbi.site = 1 THEN 'ST'
        WHEN cbi.site = 2 THEN 'CA'
        ELSE 'ST'
    END AS "サイト"
FROM classroom_basic_informations cbi
LEFT JOIN (
    SELECT classroom_id, MIN(`group`) AS `group`
    FROM job_basic_informations
    WHERE publish_flag = 1
    GROUP BY classroom_id
) jbi ON cbi.id = jbi.classroom_id
LEFT JOIN companies com ON cbi.company_id = com.id
WHERE cbi.publish_flag = 1
GROUP BY 
    cbi.brand_id,
    cbi.company_id,
    cbi.prefecture_id,
    cbi.plan,
    jbi.group,
    com.admin_note_1,
    cbi.site;
