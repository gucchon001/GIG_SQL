2025-08-01 20:21:59,676 - main - INFO - SELECT 
    CASE 
        WHEN cbi.site = 1 THEN 'ステーション'
        WHEN cbi.site = 2 THEN 'キャリア'
        ELSE 'ステーション'
    END AS "対象サイト",
    ua.id AS "応募ID",
    DATE_FORMAT(ua.created_at, '%Y/%m/%d %H:%i:%s') AS "応募日",
    uue.member_id AS "会員ID",
    ua.offer_type AS "オファーからの応募か？",
    cbi.id AS "教室ID",
    ua.job_id AS "求人ID",
    CASE 
        WHEN jbi.employment_status = 1 THEN 'アルバイト'
        WHEN jbi.employment_status = 2 THEN '業務委託'
        WHEN jbi.employment_status = 3 THEN '派遣'
        WHEN jbi.employment_status = 4 THEN '契約社員'
        WHEN jbi.employment_status = 5 THEN '正社員'
        ELSE NULL
    END AS "雇用形態",
    CASE 
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '1' THEN '集団指導（10名以上）'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '2' THEN 'グループ指導（10名以下）'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '3' THEN '個別指導'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '4' THEN 'チューター・担任助手'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '5' THEN '教材作成'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '6' THEN '事務スタッフ'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '7' THEN '試験監督'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '8' THEN '家庭教師'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '9' THEN 'オンライン指導'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '10' THEN 'その他'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '11' THEN '教室長'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '12' THEN '専任講師'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '13' THEN '管理職候補'
        WHEN JSON_UNQUOTE(JSON_EXTRACT(jbi.guidance_enum, '$[0]')) = '14' THEN '学校教員'
        ELSE NULL
    END AS "指導形態",
    uup.station_g_cd AS "最寄駅コード",
    uup.station_name AS "最寄駅",
    CASE 
        WHEN uup.current_occupation = 1 THEN '高校生（卒業見込み）'
        WHEN uup.current_occupation = 2 THEN '大学生'
        WHEN uup.current_occupation = 3 THEN '短大・専門学生'
        WHEN uup.current_occupation = 4 THEN '大学院生'
        WHEN uup.current_occupation = 5 THEN 'フリーター'
        WHEN uup.current_occupation = 6 THEN '派遣社員'
        WHEN uup.current_occupation = 7 THEN '契約社員'
        WHEN uup.current_occupation = 8 THEN '正社員'
        WHEN uup.current_occupation = 9 THEN '主婦・主夫'
        WHEN uup.current_occupation = 10 THEN '無職'
        WHEN uup.current_occupation = 11 THEN 'その他'
        ELSE NULL
    END AS "応募時の職業",
    uueb.school_name AS "学校名",
    uueb.enroll_year AS "入学年"
-- FROM clause
FROM user_applications ua
LEFT JOIN um_user_emails uue ON ua.user_id = uue.user_id AND uue.existence = 1 AND uue.member_id IS NOT NULL
LEFT JOIN um_users uu ON uue.user_id = uu.id
LEFT JOIN job_basic_informations jbi ON ua.job_id = jbi.id
LEFT JOIN classroom_basic_informations cbi ON jbi.classroom_id = cbi.id
LEFT JOIN um_user_profiles uup ON ua.user_id = uup.user_id
LEFT JOIN um_user_educational_backgrounds uueb ON ua.user_id = uueb.user_id AND uueb.school_type = 2
WHERE uue.email NOT LIKE '%tomonokai-corp%' 
    AND uue.email NOT LIKE '%jukust.jp%' 
