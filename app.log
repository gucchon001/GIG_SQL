2025-07-24 21:20:30,352 - main - INFO - SELECT
  CASE
    WHEN ua.submission_status = 1 THEN "未提出"
    WHEN ua.submission_status = 2 THEN "提出中"
    WHEN ua.submission_status = 3 THEN "差し戻し"
    WHEN ua.submission_status = 4 THEN "完了"
  END AS 提出ステータス,
  CASE
    WHEN ua.additional_reason = 1 THEN "退職日時未記入"
    WHEN ua.additional_reason = 2 THEN "採用お祝い不一致"
    WHEN ua.additional_reason = 3 THEN "応募重複確認"
    WHEN ua.additional_reason = 4 THEN "その他"
  END AS 追加確認理由,
  ua.id AS 応募ID,
  DATE_FORMAT(ua.created_at, '%Y/%m/%d') AS 応募日,
  TIME_FORMAT(ua.created_at, '%H:%i:%s') AS 応募時刻,
  cbi.id AS 教室ID,
  cbi.name AS 教室名,
  "" AS 応募媒体,
  CASE
    WHEN ua.adoption_status_company = 1 THEN "未登録"
    WHEN ua.adoption_status_company = 2 THEN "採用"
    WHEN ua.adoption_status_company = 3 THEN "不合格"
    WHEN ua.adoption_status_company = 4 THEN "連絡取れず"
    WHEN ua.adoption_status_company = 5 THEN "辞退"
    WHEN ua.adoption_status_company = 6 THEN "欠席"
    WHEN ua.adoption_status_company = 7 THEN "応募重複"
    WHEN ua.adoption_status_company = 8 THEN "対象外"
    WHEN ua.adoption_status_company = 9 THEN "保留"
    ELSE "不明"
  END AS 採用ステータス,
  DATE_FORMAT(ua.training_first_day, '%Y/%m/%d') AS 研修初日,
  CASE
    WHEN ua.confirm_enrollment = 1 THEN "◯"
    WHEN ua.confirm_enrollment = 2 THEN "×"
    ELSE NULL
  END AS 在籍確認,
  NULL AS データタイプ,
  DATE_FORMAT(ua.last_submission_datetime, '%Y/%m/%d') AS 最終提出日,
  TIME_FORMAT(ua.last_submission_datetime, '%H:%i:%s') AS 最終提出時刻,
  DATE_FORMAT(ua.billing_confirmed_at, '%Y/%m/%d') AS 請求確定日,
  NULL AS 請求確定時刻,
  ua.overdateline_count AS 提出期限超過月数,
  ua.pending_count AS 保留月数,
  ua.updated_by AS 最終変更者,
  DATE_FORMAT(ua.updated_at, '%Y/%m/%d') AS 更新日,
  TIME_FORMAT(ua.updated_at, '%H:%i:%s') AS 更新時刻,
  c.company_code AS 企業コード,
  'DUMMY' AS 最終列,
  cbi.site AS 対象サイト,
  c.company_name AS 企業名,
  c.admin_note_1 AS 管理メモ1,
  c.admin_note_2 AS 管理メモ2,
  uup.last_name AS 姓,
  uup.first_name AS 名,
  uup.last_name_kana AS 姓（カナ）,
  uup.first_name_kana AS 名（カナ）,
  DATE_FORMAT(ua.submission_deadline, '%Y/%m/%d') AS 提出期限,
  ua.memo AS メモ
-- FROM clause
FROM
user_applications ua
JOIN
job_basic_informations jbi ON jbi.id = ua.job_id
JOIN
classroom_basic_informations cbi ON cbi.id = jbi.classroom_id
JOIN
companies c ON c.id = cbi.company_id
JOIN
um_user_profiles uup ON uup.user_id = ua.user_id
WHERE ua.submission_status = 1
AND c.company_code NOT IN ("C0000106","A0001742","I0001758","I0001762","Z0001835","O0001836","Z0001837","I0001849","R0001889","Z0001999","N0002016","Q0002034","A0002046","Q0002057","X0002113","D0002124","K0002164","X0002194","A0002213","B0002250","S0002256","W0002264","G0002297","Y0002351","I0002646","T0002828","O0002830","O0002884","V0002909","J0002920","A0002936","E0002938","M0002983","B0003016","Y0003089","K0003109","U0003130","I0003150","V0003160","E0003169","A0003188","Z0003215","B0003260","Y0003261","R0003278","O0003307","P0003308","N0003313","K0003328","A0003338","X0003345","T0003347","S0003353","B0003361","L0003381","R0003526","V0003544","O0003550","O0003551","S0003560","O0003563","F0003575","I0003591","R0003600","E0003606","H0003607","P0003621","P0003623","D0003631","Q0003651","Y0003673","J0003686","G0003702","R0003714","W0003724","D0003726","J0003728","Q0003738","G0003760","Z0003762","N0003763","X0003767","Q0003773","Q0003774","I0003780","K0003785","Q0003788","K0003791","X0003792","D0003801","M0003805","X0003811","T0003837","H0003862","L0003863","V0003864","B0003866","S0003901","J0003905","M0003907","O0003914","K0003948","K0003969","B0003988","E0004083","Q0004084","E0004154","M0004170","M0004175","E0004181","F0004204","H0004250","O0004272","D0004302","S0004323","D0004433","T0004449","O0004476","K0004489","C0004491","U0004500","W0004518","L0004522","K0004531","W0004571","K0001269","N0004510","G0003768","E0003902","F0004014","F0004014","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","D0001794","E0003966","K0003968","L0004356","Y0000280","N0003971","Q0002166","T0002810","V0003133","M0003287","X0003292","Z0003535","L0004434","X0004118","E0003855","G0003979","H0004326","L0004627")
