2025-08-01 20:05:01,766 - main - INFO - SELECT
    CASE ua.submission_status
        WHEN 1 THEN '未提出'
        WHEN 2 THEN '提出中'
        WHEN 3 THEN '差し戻し'
        WHEN 4 THEN '完了'
        ELSE ''
    END AS 提出ステータス,
    CASE ua.additional_reason
        WHEN 1 THEN '退職日時未記入'
        WHEN 2 THEN '採用お祝い不一致'
        WHEN 3 THEN '応募重複確認'
        WHEN 4 THEN 'その他'
        ELSE ''
    END AS '追加確認理由',
    ua.id AS '応募ID',
    -- ↓↓↓ SELECT句の日時表示は、もとのUTCのまま表示されます ↓↓↓
    DATE(ua.created_at) AS '応募日',
    TIME(ua.created_at) AS '応募時刻',
    ua.recruited_classroom AS '教室ID',
    IFNULL(cbi.name, '') AS '教室名',
    '' AS 応募媒体,
    CASE ua.adoption_status_company
        WHEN 1 THEN '未登録'
        WHEN 2 THEN '採用'
        WHEN 3 THEN '不合格'
        WHEN 4 THEN '連絡取れず'
        WHEN 5 THEN '辞退'
        WHEN 6 THEN '欠席'
        WHEN 7 THEN '応募重複'
        WHEN 8 THEN '対象外'
        WHEN 9 THEN '保留'
        ELSE ''
    END AS '採用ステータス',
    IFNULL(ua.training_first_day, '') AS '研修初日',
    CASE ua.confirm_enrollment
        WHEN 1 THEN '○'
        WHEN 2 THEN '×'
        ELSE ''
    END AS '在籍確認',
    '' AS 'データタイプ',
    IFNULL(DATE(ua.last_submission_datetime), '') AS '最終提出日',
    IFNULL(TIME(ua.last_submission_datetime), '') AS '最終提出時刻',
    IFNULL(DATE(ua.billing_confirmed_at), '') AS '請求確定日_日付',
    IFNULL(TIME(ua.billing_confirmed_at), '') AS '請求確定時刻',
    IFNULL(ua.overdateline_count, 0) AS '提出期限超過月数',
    IFNULL(ua.pending_count, 0) AS '保留月数',
    IFNULL(ua.updated_by, '') AS '最終変更者',
    IFNULL(DATE(ua.updated_at), '') AS '更新日',
    IFNULL(TIME(ua.updated_at), '') AS '更新時刻',
    IFNULL(co.company_code, '') AS '企業コード',
    "DUMMY" AS '最終列',
    IFNULL(cbi.site, '') AS '教室サイト',
    IFNULL(co.company_name, '') AS '企業名',
    IFNULL(co.admin_note_1, '') AS '管理者メモ1',
    IFNULL(co.admin_note_2, '') AS '管理者メモ2'
-- FROM clause
FROM
    user_applications ua
INNER JOIN
    classroom_basic_informations cbi ON ua.recruited_classroom = cbi.id
INNER JOIN
    companies co ON cbi.company_id = co.id
WHERE ua.submission_status IN (2, 4) -- 「提出中」または「完了」のデータを抽出
    AND cbi.brand_id NOT IN (672, 1722, 1798, 1799, 2138, 1714, 1767, 27, 1820, 1821, 2130, 1994, 2089, 2013) AND  DATE(ua.last_submission_datetime) BETWEEN '2025-08-01' AND '2025-08-31';
